#!/usr/bin/env bash
# Pre-commit hook: fast format + lint gate.
#
# Scope is intentionally narrow so commits stay cheap (~5-15s).
# - Staged frontend src files → `prettier --check`
# - Staged frontend code (ts/tsx/js/mjs/cjs)  → `eslint --max-warnings=0`
# - Staged e2e .ts files → `prettier --check`
#
# The heavier checks (typecheck, i18n drift) live in `.githooks/pre-push`
# so they fire once per push, not once per commit.
#
# Install via `./scripts/install-hooks.sh` (sets `core.hooksPath=.githooks`
# in the local clone). The hook is opt-in per checkout — npm postinstall
# does NOT wire it up automatically, by design.
set -euo pipefail

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

# Use NUL-delimited paths everywhere so whitespace / globs / quotes in
# filenames can't break argument splitting. `mapfile -t -d ''` reads a
# NUL-terminated stream into a bash array; we then expand `"${array[@]}"`
# to pass each path as one argument verbatim.
mapfile -t -d '' staged_all < <(
  git diff --cached --name-only --diff-filter=ACMR -z || true
)

if [[ ${#staged_all[@]} -eq 0 ]]; then
  exit 0
fi

# Partition the staged list into the three groups the hook drives. We
# strip the leading "frontend/" or "e2e/" prefix here so the cd'd
# subshell can pass the remaining relative paths straight to prettier
# / eslint without re-cd'ing.
fe_format=()
fe_code=()
e2e_files=()
for path in "${staged_all[@]}"; do
  if [[ "$path" =~ ^frontend/src/.+\.(ts|tsx|css|json|md)$ ]]; then
    fe_format+=("${path#frontend/}")
  fi
  if [[ "$path" =~ ^frontend/.+\.(ts|tsx|js|mjs|cjs)$ ]]; then
    fe_code+=("${path#frontend/}")
  fi
  if [[ "$path" =~ ^e2e/.+\.ts$ ]]; then
    e2e_files+=("${path#e2e/}")
  fi
done

failed=0

if [[ ${#fe_format[@]} -gt 0 ]]; then
  echo "▸ pre-commit: frontend prettier --check (staged files)"
  if ! (cd frontend && npx --no-install prettier --check "${fe_format[@]}"); then
    echo "✗ prettier check failed on the staged files above. Run 'cd frontend && npx prettier --write <files>' to fix." >&2
    failed=1
  fi
fi

if [[ ${#fe_code[@]} -gt 0 ]]; then
  echo "▸ pre-commit: frontend eslint --max-warnings=0 (staged files)"
  if ! (cd frontend && npx --no-install eslint --max-warnings=0 "${fe_code[@]}"); then
    echo "✗ eslint failed on the staged files above. Run 'cd frontend && npx eslint --fix <files>' for autofixes." >&2
    failed=1
  fi
fi

if [[ ${#e2e_files[@]} -gt 0 ]]; then
  echo "▸ pre-commit: e2e prettier --check (staged files)"
  if ! (cd e2e && npx --no-install prettier --check "${e2e_files[@]}"); then
    echo "✗ e2e prettier check failed on the staged files above. Run 'cd e2e && npx prettier --write <files>' to fix." >&2
    failed=1
  fi
fi

if [[ $failed -ne 0 ]]; then
  echo "" >&2
  echo "Pre-commit gate failed. Fix the issues above and re-stage." >&2
  echo "Bypass once (only for emergencies) with: git commit --no-verify" >&2
  exit 1
fi

exit 0
