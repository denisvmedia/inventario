# openapi-typescript@7 declares `peer typescript@^5.x`, but the rest of the
# scaffold is on TypeScript 6 (issue #1426 / epic #1397). The peer is build-
# time only — openapi-typescript emits .d.ts via its own bundled compiler —
# so the mismatch is benign. Enabling legacy-peer-deps locally so neither
# `npm install` nor `npm ci` (in CI) trip over this. Drop the flag once
# openapi-typescript ships a release that allows TS 6.
legacy-peer-deps=true
