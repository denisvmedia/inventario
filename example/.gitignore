# Ignore data directories (contains persistent application data)
data/

# Ignore override file (contains sensitive configuration)
docker-compose.override.yaml

# Ignore environment file (contains sensitive configuration)
.env

# Ignore backup files
*.sql
*.tar.gz
backup-*

# Ignore setup.sh backups of .env / override (may contain secrets)
.env.bak.*
docker-compose.override.yaml.bak.*
