{
  "name": "inventario-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Inventario frontend — React 19 + Tailwind v4 + shadcn/ui.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "codegen": "node scripts/codegen.mjs",
    "codegen:check": "node scripts/codegen.mjs --check",
    "i18n:extract": "i18next-parser",
    "i18n:check": "node scripts/i18n-check.mjs",
    "size": "size-limit",
    "size:why": "size-limit --why",
    "lhci": "lhci autorun",
    "clean": "rm -rf dist node_modules/.tmp"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@tanstack/react-query": "5.100.9",
    "@zxcvbn-ts/core": "3.0.4",
    "@zxcvbn-ts/language-common": "3.0.4",
    "@zxcvbn-ts/language-en": "3.0.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "i18next": "26.0.10",
    "i18next-browser-languagedetector": "8.2.1",
    "i18next-resources-to-backend": "1.2.1",
    "lucide-react": "1.14.0",
    "pdfjs-dist": "5.7.284",
    "radix-ui": "1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "7.75.0",
    "react-i18next": "17.0.7",
    "react-router-dom": "7.15.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@eslint/js": "10.0.1",
    "@lhci/cli": "0.15.1",
    "@size-limit/preset-app": "12.1.0",
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/react-query-devtools": "5.100.9",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jest-axe": "3.5.9",
    "@types/node": "25.6.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.6.0",
    "i18next-cli": "1.56.11",
    "jest-axe": "10.0.0",
    "jsdom": "29.1.1",
    "msw": "2.14.5",
    "openapi-typescript": "7.13.0",
    "prettier": "3.8.3",
    "size-limit": "12.1.0",
    "swagger2openapi": "7.0.8",
    "tailwindcss": "4.2.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.2",
    "vite": "8.0.11",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": "24.15.0"
  },
  "volta": {
    "node": "24.15.0",
    "npm": "11.14.1"
  }
}
