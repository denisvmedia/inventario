# Force LF line endings for all text files
* text=auto eol=lf

# Explicitly declare text files you want to always be normalized and converted to LF on checkout
#*.go text eol=lf
#*.sh text eol=lf
#*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
